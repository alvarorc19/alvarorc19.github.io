---
interface Props {
    title: string;
    description: string;
    link: string;
    tags: string[];
}

const { title, description, link, tags } = Astro.props;
---

<div class="mb-6 pl-4 border-l-2 border-[var(--border-color)]">
    <div class="flex flex-col sm:flex-row sm:items-baseline gap-2 mb-1">
        <a
            href={link}
            class="font-bold text-lg hover:text-[var(--accent-color)] transition-colors"
        >
            {title}
        </a>
        <div class="flex gap-2">
            {
                tags.map((tag) => (
                    <span class="text-xs px-1.5 py-0.5 border border-[var(--border-color)] rounded-sm opacity-70">
                        {tag}
                    </span>
                ))
            }
        </div>
    </div>

    <p class="text-sm opacity-90 leading-relaxed max-w-2xl">
        {description}
    </p>
</div>
