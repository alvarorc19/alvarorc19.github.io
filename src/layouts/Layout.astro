---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import TableOfContents from "../components/TableOfContents.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
		<meta name="generator" content={Astro.generator} />
		<title>Alvaro - Personal Portfolio</title>
		<script is:inline>
			const storedTheme = localStorage.getItem("theme");
			const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;

			document.documentElement.classList.toggle(
				"dark",
				storedTheme ? storedTheme === "dark" : prefersDark,
			);
		</script>
	</head>
	<body class="antialiased min-h-screen flex flex-col">
		<Header />
		<main class="flex-grow w-full py-2">
			<slot />
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	/* Theme Logic is handled in global.css and ThemeToggle component */
	html {
		scroll-behavior: smooth;
		scroll-padding-top: 5rem;
	}
	body {
		max-width: 48rem; /* max-w-3xl equivalent */
		margin: 0 auto;
		padding: 2rem 1.5rem;
	}
</style>
